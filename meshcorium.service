[Unit]
Description=Meshcorium launcher
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
User=peg4tron
Group=peg4tron
WorkingDirectory=/opt/MeshCorium
ExecStartPre=+/usr/bin/bash -c "for dev in /dev/ttyACM* /dev/ttyUSB*; do [ -e \"$dev\" ] && chgrp dialout \"$dev\" && chmod g+rw \"$dev\"; done"
ExecStart=/opt/MeshCorium/meshcorium-launcher.sh --supervise
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
