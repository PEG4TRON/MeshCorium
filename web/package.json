    "vue": "^3.5.13",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.0.4",
    "vue3-emoji-picker": "^1.1.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^26.1.0",
    "vite": "^6.1.0",
    "vite-plugin-vue-devtools": "^7.7.6",
    "vitest": "^3.2.4"
  }
